-- 1. DATABASE & TABLE SETUP
-- Creating the table based on the schema visible in HR_Raw_Data_Sample

CREATE TABLE HR_Raw_Data_Sample (
    EmployeeID INT PRIMARY KEY,
    Name VARCHAR(100),
    Role VARCHAR(100),
    Department VARCHAR(50),
    MonthlySalary INT,
    AttritionStatus VARCHAR(20),
    HireDate DATE,
    OvertimeHours INT,
    PerformanceRating INT,
    TerminationDate DATE
);

